{
  "name": "org-zhixing",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A browser demo for viewing Org blog, records, and agenda data through orgize WASM.",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --pretty false",
    "harness": "typescript-project-harness .",
    "harness:json": "typescript-project-harness --json .",
    "harness:agent-snapshot": "typescript-project-harness --agent-snapshot .",
    "perf": "node scripts/bench-orgize-wasm.mjs",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "orgize": "file:../../wasm",
    "smol-toml": "^1.6.1"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "typescript-lang-project-harness": "github:tao3k/typescript-lang-project-harness#04524b55706e77080e30795b9b7cfe014d24cfce",
    "vite": "^7.2.2"
  }
}
