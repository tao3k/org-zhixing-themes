{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://org-zhixing.dev/benchmarks/scenario.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "route",
    "theme",
    "variant",
    "fixture",
    "projects",
    "actions",
    "gates"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]+$" },
    "route": { "type": "string", "pattern": "^/" },
    "theme": { "type": "string", "minLength": 1 },
    "variant": { "type": "string", "minLength": 1 },
    "fixture": { "type": "string", "minLength": 1 },
    "projects": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "enum": ["compact-phone", "modern-phone", "tablet", "desktop"] }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type"],
        "properties": {
          "type": { "enum": ["goto", "click", "scroll", "screenshot"] },
          "target": { "type": "string" },
          "value": { "anyOf": [{ "type": "string" }, { "type": "number" }] }
        }
      }
    },
    "gates": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "maxHorizontalOverflowPx",
        "maxConsoleErrors",
        "maxPageErrors",
        "minTapTargetPx"
      ],
      "properties": {
        "maxHorizontalOverflowPx": { "type": "number", "minimum": 0 },
        "maxConsoleErrors": { "type": "integer", "minimum": 0 },
        "maxPageErrors": { "type": "integer", "minimum": 0 },
        "minTapTargetPx": { "type": "number", "minimum": 1 }
      }
    }
  }
}
